# Unity ----------------------------------------------------------------------
# YAML scenes/prefabs/SOs use Unity's smart merge; do NOT let git merge them.
*.unity            merge=unityyamlmerge eol=lf -text
*.prefab           merge=unityyamlmerge eol=lf -text
*.asset            merge=unityyamlmerge eol=lf -text
*.meta             merge=unityyamlmerge eol=lf -text
*.controller       merge=unityyamlmerge eol=lf -text
*.anim             merge=unityyamlmerge eol=lf -text
*.physicMaterial   merge=unityyamlmerge eol=lf -text
*.physicsMaterial2D merge=unityyamlmerge eol=lf -text
*.mat              merge=unityyamlmerge eol=lf -text
*.lighting         merge=unityyamlmerge eol=lf -text
*.terrainlayer     merge=unityyamlmerge eol=lf -text
*.mixer            merge=unityyamlmerge eol=lf -text
*.shadervariants   merge=unityyamlmerge eol=lf -text

# Text/code ------------------------------------------------------------------
*.cs               text diff=csharp eol=lf
*.shader           text eol=lf
*.cginc            text eol=lf
*.hlsl             text eol=lf
*.uss              text eol=lf
*.uxml             text eol=lf
*.json             text eol=lf
*.md               text eol=lf
*.txt              text eol=lf
*.xml              text eol=lf
*.yml              text eol=lf
*.yaml             text eol=lf

